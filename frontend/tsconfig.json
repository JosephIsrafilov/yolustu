{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    ".next-build-1781085384132/types/**/*.ts",
    ".next-build-1781085384132/dev/types/**/*.ts",
    ".next-build-1781088943933/types/**/*.ts",
    ".next-build-1781088943933/dev/types/**/*.ts",
    ".next-build-1781089378558/types/**/*.ts",
    ".next-build-1781089378558/dev/types/**/*.ts",
    ".next-build-1781094115995/types/**/*.ts",
    ".next-build-1781094115995/dev/types/**/*.ts",
    ".next-build-1781096563614/types/**/*.ts",
    ".next-build-1781096563614/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}

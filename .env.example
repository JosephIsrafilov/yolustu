# Database - runtime pooled URL for application traffic
DATABASE_URL=postgresql://<pooled-user>:<password>@<pooled-host>:<pooled-port>/postgres?sslmode=require

# Database - direct URL for migrations/Alembic
DIRECT_DATABASE_URL=postgresql://postgres:<password>@<direct-host>:5432/postgres?sslmode=require

# Local Docker fallback
# DATABASE_URL=postgresql://yolustu_user:yolustu_password@127.0.0.1:5433/yolustu_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-me
ENVIRONMENT=development

# Web/API URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Mobile local development reference
# Android emulator API base: http://10.0.2.2:8000
# iOS simulator API base: http://localhost:8000
# Physical device API base: http://192.168.x.x:8000

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Payments
PAYMENT_PROVIDER=mock
PAYMENT_CURRENCY=AZN
PLATFORM_FEE_PERCENT=10
PAYMENT_SUCCESS_URL=
PAYMENT_CANCEL_URL=
PAYRIFF_BASE_URL=
PAYRIFF_MERCHANT_ID=
PAYRIFF_SECRET_KEY=
KAPITAL_BASE_URL=
KAPITAL_MERCHANT_ID=
KAPITAL_SECRET_KEY=

# AI / External APIs
NVIDIA_API_KEY=

# SMTP
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=yolmatessupport@gmail.com

# Notes
# Supabase API keys are not required when Supabase is used only as managed Postgres.
# Never expose SUPABASE_SERVICE_ROLE_KEY to frontend/mobile bundles.

# Backend env template
#
# The canonical full-stack environment template is:
#   ../.env.example
#
# For normal local development from the repository root:
#   copy .env.example .env
#
# This file exists only for backend-only workflows.
# Copy the required backend variables from ../.env.example if you run the API directly
# from the backend directory without docker-compose.

DATABASE_URL=postgresql://<pooled-user>:<password>@<pooled-host>:<pooled-port>/postgres?sslmode=require
DIRECT_DATABASE_URL=postgresql://postgres:<password>@<direct-host>:5432/postgres?sslmode=require

# Local fallback example (Docker PostGIS)
# DATABASE_URL=postgresql://yolustu_user:yolustu_password@127.0.0.1:5433/yolustu_db

REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

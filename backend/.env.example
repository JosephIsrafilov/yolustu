DATABASE_URL=postgresql://<pooled-user>:<password>@<pooled-host>:<pooled-port>/postgres?sslmode=require
DIRECT_DATABASE_URL=postgresql://postgres:<password>@<direct-host>:5432/postgres?sslmode=require

# Local fallback example (Docker PostGIS)
# DATABASE_URL=postgresql://yolustu_user:yolustu_password@127.0.0.1:5433/yolustu_db

REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
# Mobile dev API base examples:
# Android emulator -> http://10.0.2.2:8000
# iOS simulator -> http://localhost:8000
# Physical device -> http://192.168.x.x:8000
ENVIRONMENT=development

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NVIDIA_API_KEY=
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=yolmatessupport@gmail.com

# Supabase API keys are not required when Supabase is used only as managed Postgres.
# Never expose SUPABASE_SERVICE_ROLE_KEY to frontend bundles.

# Database
DATABASE_URL=postgresql://user:password@host:6543/postgres?sslmode=require
DIRECT_DATABASE_URL=postgresql://user:password@host:5432/postgres?sslmode=require
REDIS_URL=redis://127.0.0.1:6379/0

# Security
SECRET_KEY=your-secret-key-here-min-64-characters

# Environment
ENVIRONMENT=development
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# NVIDIA API
NVIDIA_API_KEY=nvapi-your-nvidia-api-key

# SMTP (Email)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=your-email@gmail.com

# AWS SNS SMS (EC2 should use IAM role credentials automatically)
# Optional fallback only:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
SMS_ENABLED=true
SMS_SENDER_ID=Yolmates
